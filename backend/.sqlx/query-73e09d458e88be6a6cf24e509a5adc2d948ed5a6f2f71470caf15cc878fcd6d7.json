{
  "db_name": "PostgreSQL",
  "query": "SELECT o.id, o.name, o.slug, o.created_at, o.updated_at\n           FROM organizations o\n           JOIN organization_members om ON o.id = om.organization_id\n           WHERE om.user_id = $1\n           ORDER BY o.created_at DESC\n           LIMIT $2 OFFSET $3",
