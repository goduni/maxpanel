  "query": "SELECT id, organization_id, email, role as \"role: OrgRole\",\n                  token_hash, invited_by, expires_at, accepted_at, revoked_at, created_at\n           FROM invites\n           WHERE token_hash = $1\n             AND accepted_at IS NULL\n             AND revoked_at IS NULL\n             AND expires_at > now()",
