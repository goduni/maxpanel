{
  "db_name": "PostgreSQL",
  "query": "SELECT bot_id, chat_id, chat_type, title, icon_url, participants,\n                          last_event_at, synced_at\n                   FROM bot_chats\n                   WHERE bot_id = $1\n                     AND (COALESCE(last_event_at, synced_at), chat_id) < ($2, $3)\n                   ORDER BY COALESCE(last_event_at, synced_at) DESC, chat_id DESC\n                   LIMIT $4",
